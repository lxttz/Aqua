<!-- Meta tags -->
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<%
// 如果是单页/文章，则使用 page.title，否则使用站点主标题
const pageTitle = (page && page.title) ? page.title : config.title;
const pageDescription = (page && page.description) ? page.description : config.description;
const pageUrl = (page && page.path) ? config.url + url_for(page.path) : config.url;
%>

<title><%= pageTitle %></title>
<meta name="description" content="<%= pageDescription %>">
<meta name="keywords" content="<%= config.keywords %>">
<meta name="author" content="<%= config.author %>">

<!-- Favicon -->
<link rel="icon" type="image/x-icon" href="<%- url_for('images/favicon.ico') %>">


<!-- Open Graph tags -->
<meta property="og:title" content="<%= pageTitle %>">
<meta property="og:description" content="<%= pageDescription %>">
<meta property="og:type" content="website">
<meta property="og:url" content="<%= pageUrl %>">

<!-- Twitter Card tags -->
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= pageTitle %>">
<meta name="twitter:description" content="<%= pageDescription %>">

<!-- Academicons -->
<link rel="stylesheet" href="https://unpkg.com/academicons@1.8.6/css/academicons.min.css">

<!-- Tailwind CSS -->
<link rel="stylesheet" href="<%- url_for('/css/style.css') %>">

<!-- Theme Change Script -->
<script src="https://unpkg.com/theme-change@2.0.2/index.js"></script>

<!-- Altmetric Badge -->
<script type='text/javascript' src='https://d1bxh8uas1mnw7.cloudfront.net/assets/embed.js'></script>

<!-- Dimensions Badge -->
<script async src="https://badge.dimensions.ai/badge.js" charset="utf-8"></script>

<!-- Google Adsense (disabled if not configured) -->
<% if (theme.google_adsense && theme.google_adsense !== 'your_google_adsense_id') { %>
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=<%= theme.google_adsense %>" crossorigin="anonymous"></script>
<% } %>

<!-- Umami Analytics (disabled if not configured) -->
<% if (theme.umami_id && theme.umami_id !== 'your_umami_id') { %>
<script defer src="https://cloud.umami.is/script.js" data-website-id="<%= theme.umami_id %>"></script>
<% } %>

<!-- Baidu Tongji (disabled if not configured) -->
<% if (theme.baidu_tongji && theme.baidu_tongji !== 'your_baidu_tongji_id') { %>
<script>
var _hmt = _hmt || [];
(function() {
  var hm = document.createElement("script");
  hm.src = "https://hm.baidu.com/hm.js?<%= theme.baidu_tongji %>";
  var s = document.getElementsByTagName("script")[0]; 
  s.parentNode.insertBefore(hm, s);
})();
</script>
<% } %>

<!-- Typed.js -->
<script src="https://unpkg.com/typed.js@2.0.12/dist/typed.min.js"></script>

<!-- Font Awesome -->
<link rel="stylesheet" href="https://unpkg.com/@fortawesome/fontawesome-free@6.5.1/css/all.min.css">
